    {
      "parameters": {
        "jsCode": "const raw =$json.output;\n\n// Step 1: Remove markdown code blocks (```json ... ```)\nlet cleaned = raw\n  .replace(/```json\\s*/gi, \"\")\n  .replace(/```\\s*/g, \"\")\n  .trim();\n\n// Step 2: Remove escaped newlines if present\ncleaned = cleaned.replace(/\\\\n/g, \"\");\n\n// Step 3: Parse safely\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (err) {\n  throw new Error(\"Invalid JSON from AI:\\n\" + cleaned);\n}\n\n// Step 4: Return structured output\nreturn [\n  {\n    json: parsed\n  }\n];"
      },
